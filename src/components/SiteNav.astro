---
import LinkActive from "../components/LinkActive.astro";
---

<nav class="site-nav" data-theme="theme-sage">
  <div class="nav-inner">
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-hidden="true"
    />

    <label
      for="nav-toggle"
      class="nav-burger"
      aria-label="Open navigation"
      aria-controls="site-navigation"
      aria-expanded="false"
    >
      <span></span>
    </label>

    <ul class="nav-list" id="site-navigation" data-theme="theme-sage">
      <li><LinkActive location="" text="Αρχική" /></li>
      <li><LinkActive location="approaches" text="Προσεγγίσεις" /></li>
      <li><LinkActive location="services" text="Υπηρεσίες" /></li>
      <li><LinkActive location="about" text="Βιογραφικό" /></li>
      <li><LinkActive location="contact" text="Επικοινωνία" /></li>
    </ul>

    <div class="nav-overlay"></div>
  </div>
</nav>

<script>
  const navToggle = document.getElementById('nav-toggle');
  const navLinks = document.querySelectorAll('.nav-list a');
  const navLabel = document.querySelector('.nav-burger');

  if (navToggle && navLinks.length) {
    // Update aria-expanded when menu toggles
    navToggle.addEventListener('change', (e) => {
      if (navLabel) {
        navLabel.setAttribute('aria-expanded', e.target.checked);
      }
    });

    // Close menu when clicking a link
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (window.innerWidth < 769) {
          navToggle.checked = false;
          if (navLabel) {
            navLabel.setAttribute('aria-expanded', 'false');
          }
        }
      });
    });
  }
</script>
