---
interface Props {
  author?: string;
  position?: "left" | "center" | "right"; // block position
  align?: "left" | "center" | "right";    // text alignment
  size?: "sm" | "md" | "lg";
  muted?: boolean;
  edgeMargin?: string;
}

const {
  author,
  position = "center",
  align = "center",
  size = "md",
  muted = false,
  edgeMargin = "2rem"
} = Astro.props;
---

<figure
  class={[
    "quote",
    `quote-position-${position}`,
    `quote-align-${align}`,
    `quote-size-${size}`,
    muted && "quote-muted"
  ].filter(Boolean).join(" ")}
  style={`--quote-edge-margin: ${edgeMargin};`}
>
  <blockquote>
    <slot />
  </blockquote>

  {author && <figcaption>{author}</figcaption>}
</figure>

