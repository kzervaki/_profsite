---
interface Props {
  title?: string;
  image?: string;
  theme?: string;
}

const { title, image, theme } = Astro.props;
---

<section
  class="site-page"
  {...(theme ? { "data-theme": theme } : {})}
>
  {title && (
    <header class="site-page-header">
      <h2 class="site-page-title">{title}</h1>
    </header>
  )}

  <div class="site-page-content">
    <slot />
  </div>
</section>
