---
export interface Props {
  topImageSrc?: string;
  topImageAlt?: string;
  bottomImageSrc?: string;
  bottomImageAlt?: string;
  topText?: string;
  bottomText?: string;
  textAlignment?: 'left' | 'center' | 'right' | 'justify';
  imageMargin?: string;
  // Individual image size controls
  topImageWidth?: string;
  topImageHeight?: string;
  bottomImageWidth?: string;
  bottomImageHeight?: string;
  // Fallback sizes if individual not specified
  imageWidth?: string;
  imageHeight?: string;
  roundedCorners?: boolean | string;
  mobileSpacing?: string;
  mobileImageWidth?: string;
  // Individual mobile image size controls
  topMobileImageWidth?: string;
  bottomMobileImageWidth?: string;
  gap?: string;
}

const {
  topImageSrc,
  topImageAlt = '',
  bottomImageSrc,
  bottomImageAlt = '',
  topText,
  bottomText,
  textAlignment = 'left',
  imageMargin = '1rem',
  // Individual image sizes (take precedence)
  topImageWidth,
  topImageHeight,
  bottomImageWidth,
  bottomImageHeight,
  // Fallback sizes
  imageWidth = '200px',
  imageHeight = 'auto',
  roundedCorners = false,
  mobileSpacing = '1.5rem',
  mobileImageWidth = '50%',
  // Individual mobile image sizes
  topMobileImageWidth,
  bottomMobileImageWidth,
  gap = '2rem'
} = Astro.props;

const borderRadius = typeof roundedCorners === 'string'
  ? roundedCorners
  : (roundedCorners ? '0.5rem' : '0');

// Determine actual sizes to use (individual prop > fallback)
const actualTopImageWidth = topImageWidth || imageWidth;
const actualTopImageHeight = topImageHeight || imageHeight;
const actualBottomImageWidth = bottomImageWidth || imageWidth;
const actualBottomImageHeight = bottomImageHeight || imageHeight;

// Mobile sizes
const actualTopMobileWidth = topMobileImageWidth || mobileImageWidth;
const actualBottomMobileWidth = bottomMobileImageWidth || mobileImageWidth;
---

<div
  class="intro-text"
  data-text-alignment={textAlignment}
  style={`
    --image-margin: ${imageMargin};
    --border-radius: ${borderRadius};
    --text-alignment: ${textAlignment};
    --gap: ${gap};
    --mobile-spacing: ${mobileSpacing};
    
    /* Top image sizes */
    --top-image-width: ${actualTopImageWidth};
    --top-image-height: ${actualTopImageHeight};
    --top-mobile-image-width: ${actualTopMobileWidth};
    
    /* Bottom image sizes */
    --bottom-image-width: ${actualBottomImageWidth};
    --bottom-image-height: ${actualBottomImageHeight};
    --bottom-mobile-image-width: ${actualBottomMobileWidth};
  `}
>
  <!-- Top Row: Image (top-right) and Text (top-left) -->
  <div class="row top-row">
    {topText && (
      <div class="text-block top-text">
        {topText}
        {!topText && <slot name="top-text" />}
      </div>
    )}
    
    {topImageSrc && (
      <div class="image-container top-image">
        <img
          src={topImageSrc}
          alt={topImageAlt}
          loading="lazy"
          style={{
            width: '100%',
            height: 'var(--top-image-height)',
            objectFit: 'cover',
            display: 'block'
          }}
        />
      </div>
    )}
  </div>

  <!-- Bottom Row: Text (bottom-right) and Image (bottom-left) -->
  <div class="row bottom-row">
    {bottomImageSrc && (
      <div class="image-container bottom-image">
        <img
          src={bottomImageSrc}
          alt={bottomImageAlt}
          loading="lazy"
          style={{
            width: '100%',
            height: 'var(--bottom-image-height)',
            objectFit: 'cover',
            display: 'block'
          }}
        />
      </div>
    )}
    
    {bottomText && (
      <div class="text-block bottom-text">
        {bottomText}
        {!bottomText && <slot name="bottom-text" />}
      </div>
    )}
  </div>
</div>
