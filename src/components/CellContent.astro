---
interface Props {
  title: string;
  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
}

const { title, href, target = "_self" } = Astro.props;
---

<article class="cell-content">
  {href ? (
    <a href={href} target={target} class="cell-link">
      <h3 class="cell-title">{title}</h3>
      <div class="cell-body">
        <slot />
      </div>
    </a>
  ) : (
    <div class="cell-static">
      <h3 class="cell-title">{title}</h3>
      <div class="cell-body">
        <slot />
      </div>
    </div>
  )}
</article>

<style>
  .cell-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
  }
  
  .cell-link {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: inherit;
    padding: 1rem;
    box-sizing: border-box;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .cell-static {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }
  
  .cell-link::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: currentColor;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }
  
  .cell-link:hover::before {
    opacity: 0.1;
  }
  
  /* Staggered hover animation */
  .grid-vertical .cell:nth-child(1) .cell-link { transition-delay: 0ms; }
  .grid-vertical .cell:nth-child(2) .cell-link { transition-delay: 10ms; }
  .grid-vertical .cell:nth-child(3) .cell-link { transition-delay: 20ms; }
  .grid-vertical .cell:nth-child(4) .cell-link { transition-delay: 30ms; }
  .grid-vertical .cell:nth-child(5) .cell-link { transition-delay: 40ms; }
  .grid-vertical .cell:nth-child(6) .cell-link { transition-delay: 50ms; }
  .grid-vertical .cell:nth-child(7) .cell-link { transition-delay: 60ms; }
  
  .cell-title {
    font-size: 1.25em;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .cell-link:hover .cell-title {
    transform: translateY(-2px);
  }
  
  .cell-body {
    font-size: 0.9em;
    line-height: 1.4;
    overflow: hidden;
    max-height: 100%;
    opacity: 1;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .cell-link:hover .cell-body {
    opacity: 0.9;
    transform: translateY(2px);
  }
  
  /* Keep all text visible on mobile */
  @media (max-width: 768px) {
    /* .cell-body is now visible by default - no display: none */
    
    .cell-body {
      font-size: 0.8em; /* Optional: make text slightly smaller on mobile */
      line-height: 1.3;
      opacity: 0.95;
    }
    
    .cell-title {
      margin: 0 0 0.25rem 0; /* Reduce bottom margin */
      font-size: 0.9em; /* Slightly smaller title */
    }
    
    .cell-link {
      padding: 0.5rem; /* Reduce padding to fit more content */
    }
    
    .cell-static {
      padding: 0.5rem;
    }
  }
</style>
