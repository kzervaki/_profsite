---
interface Props {
  title: string;
  href?: string;
  target?: "_blank" | "_self" | "_parent" | "_top";
}

const { title, href, target = "_self" } = Astro.props;
---

<article class="cell-content">
  {href ? (
    <a href={href} target={target} class="cell-link">
      <h3 class="cell-title">{title}</h3>
      <div class="cell-body">
        <slot />
      </div>
    </a>
  ) : (
    <div class="cell-static">
      <h3 class="cell-title">{title}</h3>
      <div class="cell-body">
        <slot />
      </div>
    </div>
  )}
</article>

<style>
  /* ================= Desktop / Base (UNCHANGED) ================= */

  .cell-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .cell-link,
  .cell-static {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    box-sizing: border-box;
  }

  .cell-link {
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cell-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: currentColor;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .cell-link:hover::before {
    opacity: 0.1;
  }

  .cell-title {
    font-size: 1.25em;
    font-weight: 600;
    margin: 0 0 0.5rem;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cell-link:hover .cell-title {
    transform: translateY(-2px);
  }

  .cell-body {
    font-size: 0.9em;
    line-height: 1.4;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .cell-link:hover .cell-body {
    opacity: 0.9;
    transform: translateY(2px);
  }

  /* ================= Mobile ONLY ================= */

  @media (max-width: 768px) {
    .cell-title {
      font-size: 0.9em;
      margin-bottom: 0.25rem;
    }

    .cell-link,
    .cell-static {
      padding: 0.5rem;
    }

    /* Show only ~60% of text height with fade */
    .cell-body {
      font-size: 0.8em;
      line-height: 1.3;
      max-height: 4.2em; /* ≈ 3 lines → ~50–75% depending on content */
      overflow: hidden;
      position: relative;
      mask-image: linear-gradient(
        to bottom,
        black 70%,
        transparent 100%
      );
    }
  }
</style>
