---
export interface Props {
  imageSrc?: string;
  imageAlt?: string;
  imagePosition?: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  textAlignment?: 'left' | 'center' | 'right' | 'justify';
  imageMargin?: string;
  imageWidth?: string;
  imageHeight?: string;
  roundedCorners?: boolean | string;
  mobileSpacing?: string;
  mobileImageWidth?: string;
}

const {
  imageSrc,
  imageAlt = '',
  imagePosition = 'top-right',
  textAlignment = 'left',
  imageMargin = '1rem',
  imageWidth = 'auto',
  imageHeight = 'auto',
  roundedCorners = false,
  mobileSpacing = '1.5rem',
  mobileImageWidth = '75%'
} = Astro.props;

// Calculate border radius
const borderRadius = typeof roundedCorners === 'string' 
  ? roundedCorners 
  : (roundedCorners ? '0.5rem' : '0');

// Determine if image is on left or right side
const isImageLeft = imagePosition.includes('left');
---

<div 
  class="text-with-image"
  style={`
    --mobile-spacing: ${mobileSpacing};
    --mobile-image-width: ${mobileImageWidth};
    --border-radius: ${borderRadius};
    --text-alignment: ${textAlignment};
    --image-margin: ${imageMargin};
    --image-position: ${isImageLeft ? 'left' : 'right'};
  `}
>
  {imageSrc && (
    <div 
      class="image-side"
      style={`
        border-radius: ${borderRadius};
        overflow: hidden;
      `}
    >
      <img
        src={imageSrc}
        alt={imageAlt}
        width={imageWidth}
        height={imageHeight}
        style="max-width: 100%; height: auto; display: block;"
      />
    </div>
  )}

  <div 
    class="text-wrapper"
    style={`text-align: ${textAlignment}; overflow-wrap: break-word; word-wrap: break-word; hyphens: auto;`}
  >
    <slot />
  </div>
</div>

<style>
  /* Desktop styles - Using CSS Grid for side-by-side layout */
  .text-with-image {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto;
    align-items: start;
    gap: var(--image-margin, 1rem);
    width: 100%;
  }

  /* When image is on left (default grid layout) */
  .text-with-image[style*="--image-position: left"] {
    grid-template-columns: auto 1fr;
  }

  .text-with-image[style*="--image-position: left"] .image-side {
    grid-column: 1;
    grid-row: 1;
  }

  .text-with-image[style*="--image-position: left"] .text-wrapper {
    grid-column: 2;
    grid-row: 1;
  }

  /* When image is on right (reversed grid layout) */
  .text-with-image[style*="--image-position: right"] {
    grid-template-columns: 1fr auto;
  }

  .text-with-image[style*="--image-position: right"] .image-side {
    grid-column: 2;
    grid-row: 1;
  }

  .text-with-image[style*="--image-position: right"] .text-wrapper {
    grid-column: 1;
    grid-row: 1;
  }

  .image-side {
    max-width: 40%;
    border-radius: var(--border-radius, 0);
    overflow: hidden;
  }

  .image-side img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .text-wrapper {
    min-width: 0; /* Prevents overflow */
    overflow-wrap: break-word;
    word-wrap: break-word;
    hyphens: auto;
  }

  @media (max-width: 768px) {
    /* Mobile responsive styles */
    .text-with-image {
      display: flex;
      flex-direction: column;
      align-items: var(--text-alignment, flex-start);
      gap: var(--mobile-spacing, 1.5rem);
    }

    .image-side {
      max-width: var(--mobile-image-width, 75%) !important;
      width: var(--mobile-image-width, 75%) !important;
      grid-column: 1 !important;
      grid-row: 1 !important;
    }

    /* Align image based on text alignment */
    .text-with-image[style*="--text-alignment: center"] .image-side {
      margin: 0 auto !important;
    }

    .text-with-image[style*="--text-alignment: right"] .image-side {
      margin-left: auto !important;
    }

    .text-with-image[style*="--text-alignment: left"] .image-side {
      margin-right: auto !important;
    }

    .text-wrapper {
      grid-column: 1 !important;
      grid-row: 2 !important;
      width: 100% !important;
    }

    /* Apply text alignment from CSS variable */
    .text-with-image[style*="--text-alignment: center"] .text-wrapper {
      text-align: center !important;
    }

    .text-with-image[style*="--text-alignment: right"] .text-wrapper {
      text-align: right !important;
    }

    .text-with-image[style*="--text-alignment: left"] .text-wrapper {
      text-align: left !important;
    }

    .text-with-image[style*="--text-alignment: justify"] .text-wrapper {
      text-align: justify !important;
    }
  }
</style>
