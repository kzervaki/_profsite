---
import BaseLayout from "../layouts/BaseLayout.astro";
import SitePage from "../components/SitePage.astro";
import IntroText from "../components/IntroText.astro";
import { CONFIG } from "../site-config";
import ServiceGrid from "../components/ServiceGrid.astro";
import ServiceCard from "../components/ServiceCard.astro";

const baseUrl = import.meta.env.BASE_URL || '/';

const services = [
  {
    id: "B",
    title: "Ατομική Ενηλίκων",
    href: `${baseUrl}/services/individual-adults`,
    description: "Δομημένος χώρος διερεύνησης των σκέψεων, των συναισθημάτων και των βιωμάτων του ώριμου ατόμου. Στο επίκεντρο βρίσκεται η μοναδική προσωπική ιστορία κάθε ανθρώπου, καθώς και ο τρόπος με τον οποίο οι εμπειρίες ζωής, οι σχέσεις και τα εσωτερικά μοτίβα επηρεάζουν τη σημερινή του λειτουργικότητα."
  },
  {
    id: "C",
    title: "Ατομική Εφήβων",
    href: `${baseUrl}/services/individual-teenagers`,
    description: "Ασφαλής χώρος έκφρασης και κατανόησης εαυτού σε μια ιδιαίτερα κρίσιμη αναπτυξιακή φάση του ατόμου. Στοχεύει στη στήριξη του εφήβου, ενισχύοντας την ψυχική του ανθεκτικότητα και τη σταδιακή του αυτονόμηση μέσα σε καταστάσεις έντονων συναισθηματικών μεταβολών και αναζήτησης ταυτότητας."
  },
  {
    id: "D",
    title: "Διαδικτυακές συνεδρίες",
    href: `${baseUrl}/services/online-sessions`,
    description: "Υποστήριξη και θεραπεία μέσω βιντεοκλήσεων, ειδικών εφαρμογών ή κρυπτογραφημένης επικοινωνίας. Παρέχεται σε περιπτώσεις όπου η φυσική παρουσία είναι δύσκολη ή ανέφικτη, ή όποτε κάποιο άτομο νιώθει πιο άνετα να ξεκινήσει θεραπεία από τον προσωπικό του χώρο. Πραγματοποιούνται με τον ίδιο τρόπο όπως οι παραδοσιακές συνεδρίες."
  },
  {
    id: "E",
    title: "Θεραπεία ζεύγους",
    href: `${baseUrl}/services/couple-therapy`,
    description: "Υποστηρικτικό και μη επικριτικό πλαίσιο εξερεύνησης της σχέσης του ζεύγους και αμοιβαίας κατανόησης των μοτίβων επικοινωνίας. Η σχέση δεν εξετάζεται απομονωμένα, αλλά ως μέρος ενός ευρύτερου συστήματος –οικογένειας, κοινωνικού περιβάλλοντος και προσωπικού ιστορικού– όπου κάθε μέλος επηρεάζει και επηρεάζεται από τους υπόλοιπους."
  },
  {
    id: "F",
    title: "Θεραπεία οικογένειας",
    href: `${baseUrl}/services/family-therapy`,
    description: "Δομημένος χώρος αμοιβαίας διερεύνησης των σχέσεων και αλληλοκατανόησης μεταξύ των μελών της οικογένειας. Στόχος είναι να ενισχυθεί η επικοινωνία, η συναισθηματική σύνδεση και η συνολική ισορροπία του οικογενειακού συστήματος, πέρα από την αντιμετώπιση μόνο μεμονωμένων προβλημάτων ή προβληματικών συμπεριφορών."
  },
  {
    id: "G",
    title: "Συμβουλευτική Γονέων",
    href: `${baseUrl}/services/parents-counseling`,
    description: "Υποστηρικτικό πλαίσιο επεξεργασίας των προκλήσεων της γ��νεϊκότητας και καλύτερης κατανόησης των αναγκών των παιδιών. Η διαδικασία αυτή δεν επικεντρώνεται σε «σωστούς» ή «λάθους» τρόπους ανατροφής, αλλά στην κατανόηση των μοναδικών δυναμικών που διαμορφώνουν την επικοινωνία και τη λειτουργικότητα της κάθε οικογένειας."
  }
];
---

<BaseLayout title="Αρχική">

  <SitePage
    title=""
  >
    <IntroText
      topImageSrc=`${import.meta.env.BASE_URL}/images/intro-image-1.jpg`
      topImageWidth="440px"
      topImageHeight="330px"
      topText="Η ψυχοθεραπεία συνιστά έναν ουσιαστικό και ασφαλή χώρο εσωτερικής διερεύνησης, όπου το άτομο έχει τη δυνατότητα να προσεγγίσει σε βάθος τον εαυτό του, τα βιώματά του, τις διαπροσωπικές του δυναμικές και το συναισθηματικό του τοπίο. Θεμελιώνεται σε μια σχέση συνεργατική και αυθεντική, όπου η αποδοχή της παρούσας εμπειρίας συνυπάρχει με τη δυνατότητα για ουσιαστική αλλαγή. Ο σκοπός της δεν περιορίζεται στη συμπτωματική ανακούφιση, αλλά εκτείνεται στη βαθύτερη ενίσχυση της αυτογνωσίας και της ψυχικής ανθεκτικότητας. Μέσα από μια διαδικασία προσωπικής εξερεύνησης και νοηματοδότησης της εμπειρίας, καλλιεργείται η συναισθηματική ισορροπία, ενδυναμώνεται η ικανότητα αυτορρύθμισης και ενισχύεται η δυνατότητα για αυθεντικές, ικανοποιητικές και ουσιαστικές σχέσεις — τόσο με τον εαυτό όσο και με τους άλλους."

      bottomImageSrc=`${import.meta.env.BASE_URL}/images/intro-image-2.webp`
      bottomImageWidth="390px"
      bottomText="Η θεραπευτική μου προσέγγιση είναι συνθετική, αντλώντας κυρίαρχα θεωρητικά εργαλεία και κλινική γνώση από τη Συστημική Ψυχοθεραπεία και τη Διαλεκτική Συμπεριφορική Ψυχοθεραπεία (DBT). Παράλληλα, ενσωματώνει εκλεκτικά στοιχεία  της ψυχοδυναμικής οπτικής, της θεωρίας των αντικειμενοτρόπων σχέσεων και της θεωρίας δεσμού, το γνωσιακό-συμπεριφορικό μοντέλο, αλλά και από τις σύγχρονες προσεγγίσεις της τραυματολογίας. Μέσα από αυτή τη σύνθεση, δίνεται έμφαση τόσο στη σχεσιακή, κυκλική διάσταση των δυσκολιών, όσο και στην κατανόηση ασυνείδητων διεργασιών και βιοψυχοκοινωνικών επιρροών, με γνώμονα την ανάπτυξη ασφαλέστερων  και λειτουργικών τρόπων σύνδεσης με τον εαυτό και τους άλλους. Εάν διανύετε μια περίοδο συναισθηματικής έντασης, προσωπικών δυσκολιών ή επαναλαμβανόμενων προκλήσεων στις σχέσεις σας, η ψυχοθεραπεία μπορεί να αποτελέσει ένα ασφαλές και σταθερό σημείο υποστήριξης και ένα εφαλτήριο προσωπικής εξέλιξης"
      textAlignment="justify"
      imageWidth="250px"
      roundedCorners={true}
      gap="2.1rem"
      mobileImageWidth="80%"
    />

    <ServiceGrid columns={3}>
      <ServiceCard
        title="Ατομική Ενηλίκων"
        description="Δομημένος και ασφαλής χώρος διερεύνησης των σκέψεων, συναισθημάτων και βιωμάτων του ώριμου ατόμου"
        href=`${import.meta.env.BASE_URL}services/individual-therapy-adults`
        image="images/service-individual-adults.png"
      />
      <ServiceCard
        title="Ατομική Εφήβων"
        description="Ασφαλής χώρος έκφρασης και κατανόησης εαυτού σε μια ιδιαίτερα κρίσιμη αναπτυξιακή φάση του ατόμου"
        href=`${import.meta.env.BASE_URL}services/individual-therapy-teenagers`
        image="images/service-individual-teenagers.png"
      />
      <ServiceCard
        title="Διαδικτυακές Συνεδρίες"
        description="Υποστήριξη και θεραπεία μέσω βιντεοκλήσεων, ειδικών εφαρμογών ή κρυπτογραφημένης επικοινωνίας"
        href=`${import.meta.env.BASE_URL}services/online-sessions`
        image="images/service-online-sessions.png"
      />
      <ServiceCard
        title="Θεραπεία Ζεύγους"
        description="Μη επικριτικό και υποστηρικτικό πλαίσιο εξερεύνσης της σχέσης του ζεύγους και κατανόησης των μοτίβων επικοινωνίας"
        href=`${import.meta.env.BASE_URL}services/couple-therapy`
        image="images/service-couple-therapy.png"
      />
      <ServiceCard
        title="Θεραπεία Οικογένειας"
        description="Δομημένος χώρος αμοιβαίας διερεύνησης των σχέσεων μεταξύ και αλληλοκατανόησης μεταξύ των μελών της οικογένειας"
        href=`${import.meta.env.BASE_URL}services/family-therapy`
        image="images/service-family-therapy.png"
      />
      <ServiceCard
        title="Συμβουλευτική Γονέων"
        description="Υποστηρικτικό πλάισιο επεξεργασίας των προκλήσεων της γονεϊκότητας και καλύτερης κατανόησης των αναγκών των παιδιών"
        href=`${import.meta.env.BASE_URL}services/parents-counseling`
        image="images/service-parents-counseling.png"
      />
    </ServiceGrid>

  </SitePage>
</BaseLayout>

